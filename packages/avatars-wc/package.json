{
	"name": "@outpacelabs/avatars-wc",
	"version": "0.1.0",
	"description": "Web Component (Custom Element) for @outpacelabs/avatars — works with Angular, Lit, vanilla JS, Alpine, HTMX, and any framework.",
	"keywords": [
		"avatars",
		"gradient",
		"web-component",
		"custom-element",
		"angular",
		"lit",
		"vanilla"
	],
	"homepage": "https://avatars.outpace.systems",
	"repository": {
		"type": "git",
		"url": "https://github.com/outpacestudios/avatars.git",
		"directory": "packages/avatars-wc"
	},
	"author": "Outpace Studios (https://outpacestudios.com)",
	"license": "CC-BY-4.0",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": ["dist", "README.md", "LICENSE"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@outpacelabs/avatars": "workspace:*"
	},
	"devDependencies": {
		"tsup": "^8.3.5",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
