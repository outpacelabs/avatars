{
	"name": "@outpacelabs/avatars-svelte",
	"version": "0.1.0",
	"description": "Svelte component for @outpacelabs/avatars — 50 handcrafted gradient avatars.",
	"keywords": [
		"avatars",
		"gradient",
		"svelte",
		"sveltekit",
		"profile-pictures"
	],
	"homepage": "https://avatars.outpace.systems",
	"repository": {
		"type": "git",
		"url": "https://github.com/outpacelabs/avatars.git",
		"directory": "packages/avatars-svelte"
	},
	"author": "Outpace Studios (https://outpacestudios.com)",
	"license": "CC-BY-4.0",
	"type": "module",
	"sideEffects": false,
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "svelte-package -i src -o dist",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@outpacelabs/avatars": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^4.0.0 || ^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.3.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
