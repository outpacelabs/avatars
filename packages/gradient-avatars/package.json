{
	"name": "@outpacelabs/gradient-avatars",
	"version": "0.1.0",
	"description": "Deterministic mesh-gradient avatar generator. Every seed renders a unique gradient on a canvas — framework-agnostic, zero dependencies, no stored images.",
	"keywords": [
		"avatars",
		"gradient",
		"mesh-gradient",
		"generative",
		"identicon",
		"canvas",
		"profile-pictures"
	],
	"homepage": "https://avatars.outpacestudios.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/outpacelabs/avatars.git",
		"directory": "packages/gradient-avatars"
	},
	"bugs": {
		"url": "https://github.com/outpacelabs/avatars/issues"
	},
	"author": "Outpace Studios (https://outpacestudios.com)",
	"license": "CC-BY-4.0",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"devDependencies": {
		"tsup": "^8.3.5",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
